# =========================================================
# ILOT COCO BEACH - IP-only deployment env
# Copy to .env on the VPS:  cp .env.vps.example .env
# Then fill in real values. Used by docker-compose.vps.yml
# =========================================================

# Public IP of your Hostinger VPS (no http://, no port)
VPS_IP=CHANGE_ME_VPS_IP

# Database password (strong random string)
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# JWT signing secret  ->  generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# MinIO (object storage) credentials
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# Email (Brevo) - optional for first launch; password-reset emails
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=contact@example.com
